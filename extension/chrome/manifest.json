{
  "manifest_version": 3,
  "name": "BuscaLogo Agent",
  "version": "1.0.8",
  "description": "Verifica se a página está indexada no BuscaLogo Agent local e sugere adicionar à busca.",
  "homepage_url": "https://buscalogo.com",
  "author": "BuscaLogo",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:9970/*",
    "http://localhost:9970/*",
    "http://*.bl/*"
  ],
  "optional_host_permissions": [
    "http://127.0.0.1:9970/*",
    "http://localhost:9970/*",
    "http://*.bl/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BuscaLogo Agent",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
